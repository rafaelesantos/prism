{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Prism",
  "logo": {
    "dark": "/docs/logo/logo.svg",
    "light": "/docs/logo/logo.svg"
  },
  "favicon": "/docs/favicon.svg",
  "colors": {
    "primary": "#FF5C00",
    "light": "#FF7A33",
    "dark": "#CC4A00",
    "background": {
      "dark": "#0A0A0A",
      "light": "#FAFAFA"
    }
  },
  "font": {
    "headings": {
      "family": "JetBrains Mono",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "grid"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": "vitesse-dark"
    }
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/byescaleira/prism"
    }
  ],
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "/docs/introduction"
  },
  "tabs": [
    {
      "name": "Server",
      "url": "docs/core"
    },
    {
      "name": "Client",
      "url": "docs/foundation"
    }
  ],
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/byescaleira/prism"
    },
    {
      "name": "Swift Package",
      "icon": "swift",
      "url": "https://github.com/byescaleira/prism"
    }
  ],
