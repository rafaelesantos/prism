{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Prism",
  "logo": {
    "dark": "/logo/logo.svg",
    "light": "/logo/logo.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#FF5C00",
    "light": "#FF7A33",
    "dark": "#CC4A00",
    "background": {
      "dark": "#0A0A0A",
      "light": "#FAFAFA"
    }
  },
  "font": {
    "headings": {
      "family": "JetBrains Mono",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "grid"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": "vitesse-dark"
    }
  },
  "topbarLinks": [
    {
      "name": "GitHub",
      "url": "https://github.com/byescaleira/prism"
    }
  ],
  "topbarCtaButton": {
    "name": "Get Started",
    "url": "/introduction"
  },
  "tabs": [
    {
      "name": "Server",
      "url": "server"
    }
  ],
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/byescaleira/prism"
    }
  ],
  "navigation": [
    {
      "group": "Getting Started",
      "pages": [
        "introduction",
        "quickstart",
        "installation"
      ]
